{
    "name": "xver/micartera-domain",
    "description": "MiCartera Domain",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Xver\\MiCartera\\Domain\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "require": {
        "php": "^8.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.3",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.5",
        "symfony/monolog-bundle": "^4.0",
        "symfony/runtime": "^8.0",
        "symfony/uid": "^8.0",
        "symfony/yaml": "^8.0",
        "xver/php-auth-core": "^1.0",
        "xver/php-app-core": "^1.0"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.1",
        "phpunit/phpunit": "^12.1",
        "symfony/finder": "^8.0",
        "vimeo/psalm": "^6.10"
    },
    "repositories":[
        {
            "type": "vcs",
            "url": "https://github.com/sgurdiel/php-app-core.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sgurdiel/php-auth-core.git"
        }
    ],
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    }
}
